{
  "name": "euchrenow",
  "version": "1.0.0",
  "description": "A multiplayer Eurchre card game web application.",
  "homepage": "https://github.com/warliang/EuchreNow#readme",
  "bugs": {
    "url": "https://github.com/warliang/EuchreNow/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/warliang/EuchreNow.git"
  },
  "license": "ISC",
  "author": "warliang",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "client": "npm run dev --workspace=apps/client",
    "server": "npm run dev --workspace=apps/server",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest",
    "test:client": "npm run test --workspace=apps/client"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "concurrently": "^9.2.1",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "tailwind-merge": "^3.5.0"
  }
}
